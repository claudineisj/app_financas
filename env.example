# =============================================================================
# VARIÁVEIS DE AMBIENTE — Minhas Finanças Pessoais
# =============================================================================
# Copie este arquivo para .env.local e preencha com seus valores reais.
# O arquivo .env.local está no .gitignore e NUNCA deve ser enviado ao GitHub.
#
# Para deploy na Vercel: adicione estas variáveis em
# Project Settings → Environment Variables
# =============================================================================

# ------------------------------------------------------------------------------
# SUPABASE
# Encontre em: https://supabase.com → seu projeto → Project Settings → API
# ------------------------------------------------------------------------------

# URL pública do projeto (seguro expor — é o endereço da API)
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave anônima/publishable (seguro expor — a segurança é feita pelo RLS no banco)
# Esta chave só permite operações que as políticas RLS autorizam para cada usuário
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key

# ------------------------------------------------------------------------------
# ATENÇÃO: chaves que NUNCA devem aparecer aqui ou no código
# ------------------------------------------------------------------------------
# - service_role key (acesso total ao banco, sem RLS) → usar apenas server-side
#   se necessário no futuro, usar sem prefixo NEXT_PUBLIC_
# - JWT secret do Supabase
# - Qualquer outro segredo de terceiros
# ------------------------------------------------------------------------------
